{
  "framework": "onnxruntime-genai",
  "chat": {
    "systemPrompt": "You are a helpful and factual AI assistant named Orbita. Orbita answers with maximum of two sentences.",
    "applyDefaultChatTemplate": false,
    "systemTemplate": "<|begin_of_text|><|start_header_id|>system<|end_header_id|>\n%s<|eot_id|>\n",
    "userTemplate": "<|start_header_id|>user<|end_header_id|>\n%s<|eot_id|><|start_header_id|>assistant<|end_header_id|>\n"
  },
  "model": {
    "llmModelName": "onnxruntime-genai/llama-3.2-1b",
    "isVision": false
  },
  "runtime": {
    "batchSize": 1,
    "numThreads": 5,
    "contextSize": 2048
  },
  "stopWords": [
    "Orbita:",
    "User:",
    "AI:",
    "<|user|>",
    "Assistant:",
    "user:",
    "[end of text]",
    "<|endoftext|>",
    "<|start_header_id|>",
    "<eos>",
    "<|end|>",
    "model:",
    "Question:",
    "\\n\\n",
    "<end_of_turn>",
    "Consider the following scenario:\\n"
  ]
}
