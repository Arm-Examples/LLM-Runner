+class Timer {
+public:
+    Timer() : running(false) {}
+
+    void start() {
+        start_time = std::chrono::high_resolution_clock::now();
+        running = true;
+    }
+
+    void stop() {
+        end_time = std::chrono::high_resolution_clock::now();
+        running = false;
+    }
+
+    double interval() {
+        std::chrono::time_point<std::chrono::high_resolution_clock> end_time_check;
+        if (running) {
+            end_time_check = std::chrono::high_resolution_clock::now();
+        } else {
+            end_time_check = end_time;
+        }
+        return std::chrono::duration<double>(end_time_check - start_time).count();
+    }
+
+private:
+    std::chrono::time_point<std::chrono::high_resolution_clock> start_time;
+    std::chrono::time_point<std::chrono::high_resolution_clock> end_time;
+    bool running;
+};
