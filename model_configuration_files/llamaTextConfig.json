{
  "llmModelName" : "llama.cpp/model.gguf",
  "batchSize"    : 256,
  "numThreads"   : 5,
  "systemPrompt" : "You are a helpful and factual AI assistant named Orbita. Orbita answers with maximum of two sentences.",
  "applyDefaultChatTemplate" : true,
  "defaultChatTemplate" : {
    "systemTemplate" : "system: %s",
    "userTemplate"   : "user: %s\nassistant:"
  },
  "stopWords" : [
    "Orbita:",
    "User:",
    "AI:",
    "<|user|>",
    "Assistant:",
    "user:",
    "[end of text]",
    "<|endoftext|>",
    "<|start_header_id|>",
    "<eos>",
    "<|end|>",
    "model:",
    "Question:",
    "\\n\\n",
    "<end_of_turn>",
    "Consider the following scenario:\\n"
  ],
  "inputModalities" : ["text"],
  "outputModalities" : ["text"]
}
